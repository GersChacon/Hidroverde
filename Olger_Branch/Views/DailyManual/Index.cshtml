@model IEnumerable<HidroverdeDigital.Models.DailyProcess>
@{
    ViewData["Title"] = "Manual Diario Operativo";
    var completions = ViewBag.Completions as List<HidroverdeDigital.Models.DailyProcessCompletion>;
    var today = ViewBag.Today as string;
    var empleadoId = ViewBag.EmpleadoId as int?;
}

<div class="container">
    <!-- Header -->
    <header class="header">
        <div class="logo">
            <h1><i class="fas fa-clipboard-list"></i> Manual Diario Operativo</h1>
            <p>Procesos estandarizados para operaciones diarias</p>
        </div>
        <div class="header-actions">
            <a href="@Url.Action("Index", "Dashboard")" class="btn-back">
                <i class="fas fa-arrow-left"></i> Volver al Dashboard
            </a>
            <div class="date-display">
                <i class="fas fa-calendar-alt"></i>
                <span id="current-date">@today</span>
            </div>
        </div>
    </header>

    <!-- Stats Bar -->
    <div class="stats-bar manual-stats">
        <div class="stat-item">
            <div class="stat-value" id="total-count">@Model.Count()</div>
            <div class="stat-label">Pasos Totales</div>
        </div>
        <div class="stat-item">
            <div class="stat-value" id="completed-count">0</div>
            <div class="stat-label">Completados</div>
        </div>
        <div class="stat-item">
            <div class="stat-value">@Model.Sum(p => p.EstimatedMinutes ?? 0)</div>
            <div class="stat-label">Minutos Estimados</div>
        </div>
        <div class="stat-item">
            <div class="stat-value" id="pending-count">@Model.Count()</div>
            <div class="stat-label">Pendientes</div>
        </div>
    </div>

    <!-- Daily Manual Content -->
    <main class="manual-content">
        @foreach (var category in Model.GroupBy(p => p.Category))
        {
            var categoryName = category.Key;
            var categoryMinutes = category.Sum(p => p.EstimatedMinutes ?? 0);
            var categoryCompleted = completions?.Count(c => category.Any(p => p.ProcessId == c.ProcessId && c.Status == "COMPLETED")) ?? 0;
            
            <section class="category-section">
                <div class="category-header @categoryName.ToLower()">
                    <h2>
                        <i class="@GetCategoryIcon(categoryName)"></i> 
                        @categoryName (@categoryMinutes minutos estimados)
                    </h2>
                    <div class="category-progress">
                        <span class="progress-text">@categoryCompleted/@category.Count() completados</span>
                        <div class="progress-bar small">
                            @{
                                var progressPercentage = category.Count() > 0 ? (categoryCompleted * 100 / category.Count()) : 0;
                            }
                            <div class="progress-fill" style="width: @progressPercentage%"></div>
                        </div>
                    </div>
                </div>
                
                <div class="process-list">
                    @foreach (var process in category.OrderBy(p => p.StepNumber))
                    {
                        var isCompleted = completions?.Any(c => c.ProcessId == process.ProcessId && 
                                                               c.EmpleadoId == empleadoId && 
                                                               c.Status == "COMPLETED") ?? false;
                        
                        <div class="process-item @(isCompleted ? "completed" : "")" 
                             data-id="@process.ProcessId" 
                             data-category="@process.Category">
                            <div class="process-number">@process.StepNumber</div>
                            <div class="process-content">
                                <div class="process-title">@process.ProcessTitle</div>
                                <div class="process-description">@process.Description</div>
                                <div class="process-meta">
                                    @if (process.EstimatedMinutes.HasValue)
                                    {
                                        <span class="time-estimate">
                                            <i class="far fa-clock"></i> @process.EstimatedMinutes min
                                        </span>
                                    }
                                    @if (process.RequiresConfirmation)
                                    {
                                        <span class="requires-confirmation">
                                            <i class="fas fa-check-circle"></i> Requiere confirmación
                                        </span>
                                    }
                                </div>
                            </div>
                            <div class="process-actions">
                                @if (isCompleted)
                                {
                                    <span class="completion-status">
                                        <i class="fas fa-check-circle"></i> Completado
                                    </span>
                                }
                                else
                                {
                                    <button class="btn-complete" onclick="completeProcess(@process.ProcessId, '@process.ProcessTitle')">
                                        <i class="fas fa-check"></i> Completar
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>
            </section>
        }
    </main>

    <!-- Completion Modal -->
    <div id="completionModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-check-circle"></i> Completar Proceso</h3>
                <button class="close-modal" onclick="closeModal()">&times;</button>
            </div>
            <div class="modal-body">
                <p id="modalProcessTitle"></p>
                <div class="form-group">
                    <label for="observations"><i class="fas fa-comment"></i> Observaciones (opcional):</label>
                    <textarea id="observations" rows="3" placeholder="Agregue observaciones sobre este proceso..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" onclick="closeModal()">Cancelar</button>
                <button class="btn-primary" onclick="confirmCompletion()">Confirmar Completado</button>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="footer">
        <p>Sistema de Manual Diario • Hidroverde Digital • <span id="completion-rate">0% completado</span></p>
        @if (empleadoId.HasValue)
        {
            <button class="btn-reset" onclick="resetDailyManual()">
                <i class="fas fa-redo"></i> Reiniciar para hoy
            </button>
        }
    </footer>
</div>

@section Scripts {
    <script>
        let currentProcessId = null;
        let currentProcessTitle = null;

        // Load progress on page load
        document.addEventListener('DOMContentLoaded', function() {
            updateProgress();
        });

        function completeProcess(processId, processTitle) {
            currentProcessId = processId;
            currentProcessTitle = processTitle;
            
            document.getElementById('modalProcessTitle').textContent = 
                `¿Marcar "${processTitle}" como completado?`;
            document.getElementById('observations').value = '';
            document.getElementById('completionModal').style.display = 'flex';
        }

        async function confirmCompletion() {
            if (!currentProcessId) return;
            
            const observations = document.getElementById('observations').value;
            
            try {
                const response = await fetch('@Url.Action("MarkComplete", "DailyManual")/' + currentProcessId, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `observations=${encodeURIComponent(observations)}`
                });
                
                if (response.ok) {
                    const result = await response.json();
                    if (result.success) {
                        closeModal();
                        location.reload(); // Refresh to show updated status
                    }
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error al completar el proceso');
            }
        }

        async function updateProgress() {
            try {
                const response = await fetch('@Url.Action("GetProgress", "DailyManual")');
                if (response.ok) {
                    const data = await response.json();
                    
                    document.getElementById('completed-count').textContent = data.completed;
                    document.getElementById('pending-count').textContent = data.total - data.completed;
                    
                    const completionRate = data.total > 0 ? 
                        Math.round((data.completed / data.total) * 100) : 0;
                    document.getElementById('completion-rate').textContent = 
                        `${completionRate}% completado`;
                }
            } catch (error) {
                console.error('Error loading progress:', error);
            }
        }

        function closeModal() {
            document.getElementById('completionModal').style.display = 'none';
            currentProcessId = null;
            currentProcessTitle = null;
        }

        function resetDailyManual() {
            if (confirm('¿Está seguro de que desea reiniciar el manual diario? Esto borrará todos sus procesos completados de hoy.')) {
                // Implement reset logic - might need a new endpoint
                location.reload();
            }
        }

        // Close modal when clicking outside
        window.onclick = function(event) {
            const modal = document.getElementById('completionModal');
            if (event.target === modal) {
                closeModal();
            }
        };
    </script>
}

@functions {
    string GetCategoryIcon(string category)
    {
        return category switch
        {
            "Opening" => "fas fa-sun",
            "Operation" => "fas fa-cogs",
            "Closing" => "fas fa-moon",
            _ => "fas fa-list"
        };
    }
}